---
import "../styles/global.css";
import { Font } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title?: string;
  description?: string;
  image?: ImageMetadata;
  pubDate?: Date;
  updatedDate?: Date;
  canonicalURL?: string;
}

const {
  title = "Julius Dockwarder — Fractional Engineering Partner",
  description = "Fractional engineering partnership for product teams that care about craft.",
  image,
  pubDate,
  updatedDate,
  canonicalURL,
} = Astro.props;

const pageURL = canonicalURL ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = image ? new URL(image.src, Astro.site).toString() : undefined;
const ogType = pubDate ? "article" : "website";
---

<!doctype html>
<html lang="en" class="lg:h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-ibm-plex-mono" preload />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageURL} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
  </head>
  <body class="px-6 font-sans leading-relaxed antialiased text-neutral-600 bg-neutral-50">
    <slot />
  </body>
</html>
