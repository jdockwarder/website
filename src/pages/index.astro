---
import Layout from "../layouts/Layout.astro";

const pillars = [
  {
    number: "01",
    title: "Ownership",
    text: "Shared ownership. Whether I work independently or integrate with your team, everyone comes along.",
  },
  {
    number: "02",
    title: "Trust",
    text: "Shared ownership. Whether I work independently or integrate with your team, everyone comes along.",
  },
  {
    number: "03",
    title: "Creativity",
    text: "Shared ownership. Whether I work independently or integrate with your team, everyone comes along.",
  },
  {
    number: "04",
    title: "Maintenance",
    text: "Shared ownership. Whether I work independently or integrate with your team, everyone comes along.",
  },
  {
    number: "05",
    title: "Ownership",
    text: "Shared ownership. Whether I work independently or integrate with your team, everyone comes along.",
  },
  {
    number: "06",
    title: "Ownership",
    text: "Shared ownership. Whether I work independently or integrate with your team, everyone comes along.",
  },
];
---

<Layout>
  <section class="grid gap-4 grid-cols-1 md:grid-cols-2 xl:pt-8 transition-[padding]">
    <div class="bg-neutral-50 shadow-card p-1 rounded-3xl md:col-span-2">
      <div
        class="bg-white rounded-[calc(var(--radius-3xl)-4px)] border border-black/10 overflow-hidden"
      >
        <div class="px-6 py-4 bg-neutral-50 border-b border-black/5">
          <span class="text-xs font-mono uppercase">In just a few words</span>
        </div>
        <div class="px-6 py-5 pb-6">
          <p class="text-neutral-600">
            I’ve spent the last fifteen years building 0→1 products for the
            world’s top tech companies. Today, I partner with founders to bring
            their ideas to life. As your design partner, I will:
          </p>
        </div>
      </div>
    </div>
    <div class="bg-neutral-50 shadow-card p-1 rounded-3xl md:col-span-2">
      <div
        class="bg-white rounded-[calc(var(--radius-3xl)-4px)] border border-black/10 overflow-hidden"
      >
        <div class="px-6 py-4 bg-neutral-50 border-b border-black/5">
          <span class="text-xs font-mono uppercase">About my process</span>
        </div>
        <div class="grid md:grid-cols-2 overflow-hidden">
          {
            pillars.map((pillar) => {
              return (
                <div class="px-6 pt-4 pb-5 outline-[0.5px] outline-neutral-200">
                  <div class="flex items-baseline gap-2">
                    <span class="font-mono text-xs text-neutral-600 tabular-nums">
                      {pillar.number}
                    </span>
                    <span class="text-sm text-neutral-600">{pillar.title}</span>
                  </div>
                  <p class="mt-1 text-pretty text-sm">{pillar.text}</p>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
